# ─────────────────────────────────────────────
# GeezOS Frontend — Environment Variables
# Copy to .env.local — NEVER commit to GitHub
# ─────────────────────────────────────────────

# Backend API URL
API_URL=https://geezos-api-a0gcdncwefdchgf3.eastus2-01.azurewebsites.net

# Auth0 — get from auth0.com dashboard
AUTH0_SECRET=use-openssl-rand-base64-32-to-generate
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://YOUR_AUTH0_DOMAIN.us.auth0.com
AUTH0_CLIENT_ID=YOUR_AUTH0_CLIENT_ID
AUTH0_CLIENT_SECRET=YOUR_AUTH0_CLIENT_SECRET

# Public variables (safe to expose)
NEXT_PUBLIC_API_URL=https://geezos-api-a0gcdncwefdchgf3.eastus2-01.azurewebsites.net
NEXT_PUBLIC_APP_NAME=GeezOS
NEXT_PUBLIC_COMPANY=GEEZ EXPRESS LLC
